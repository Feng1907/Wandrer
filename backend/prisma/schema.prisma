generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  phone         String?
  avatar        String?
  role          String         @default("CUSTOMER")
  loyaltyPoints Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  bookings      Booking[]
  reviews       Review[]
  wishlist      Wishlist[]
  notifications Notification[]
  guide         Guide?
}

model Tour {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       @db.NVarChar(Max)
  highlights   String       @db.NVarChar(Max)
  includes     String       @db.NVarChar(Max)
  excludes     String       @db.NVarChar(Max)
  cancelPolicy String       @db.NVarChar(Max)
  basePrice    Decimal      @db.Decimal(18, 2)
  childPrice   Decimal      @db.Decimal(18, 2)
  duration     Int
  maxCapacity  Int
  category     String
  status       String       @default("DRAFT")
  featured     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  images      TourImage[]
  itineraries Itinerary[]
  departures  Departure[]
  reviews     Review[]
  wishlist    Wishlist[]
}

model TourImage {
  id        String  @id @default(cuid())
  tourId    String
  url       String
  publicId  String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  tour      Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model Itinerary {
  id            String  @id @default(cuid())
  tourId        String
  day           Int
  title         String
  description   String  @db.NVarChar(Max)
  meals         String
  accommodation String?

  tour          Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model Departure {
  id             String    @id @default(cuid())
  tourId         String
  departureDate  DateTime
  returnDate     DateTime
  availableSlots Int
  priceOverride  Decimal?  @db.Decimal(18, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  tour      Tour              @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  guides    GuideAssignment[]
}

model Booking {
  id              String    @id @default(cuid())
  userId          String
  departureId     String
  subtotal        Decimal   @db.Decimal(18, 2)
  discountAmount  Decimal   @db.Decimal(18, 2) @default(0)
  totalPrice      Decimal   @db.Decimal(18, 2)
  status          String    @default("PENDING")
  specialRequests String?   @db.NVarChar(Max)
  contactName     String
  contactEmail    String
  contactPhone    String
  discountCodeId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User               @relation(fields: [userId], references: [id])
  departure    Departure          @relation(fields: [departureId], references: [id])
  discountCode DiscountCode?      @relation(fields: [discountCodeId], references: [id])
  passengers   BookingPassenger[]
  payment      Payment?
}

model BookingPassenger {
  id        String    @id @default(cuid())
  bookingId String
  fullName  String
  dob       DateTime?
  idNumber  String?
  type      String    @default("ADULT")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  amount        Decimal   @db.Decimal(18, 2)
  provider      String
  transactionId String?
  status        String    @default("PENDING")
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  booking       Booking   @relation(fields: [bookingId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  tourId    String
  rating    Int
  comment   String   @db.NVarChar(Max)
  images    String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tour      Tour     @relation(fields: [tourId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  tourId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tour      Tour     @relation(fields: [tourId], references: [id])

  @@unique([userId, tourId])
}

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String
  value         Decimal   @db.Decimal(18, 2)
  minOrderValue Decimal   @db.Decimal(18, 2) @default(0)
  usageLimit    Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  bookings      Booking[]
}

model Guide {
  id          String  @id @default(cuid())
  userId      String  @unique
  bio         String? @db.NVarChar(Max)
  languages   String
  experience  Int     @default(0)
  isAvailable Boolean @default(true)

  user        User              @relation(fields: [userId], references: [id])
  assignments GuideAssignment[]
}

model GuideAssignment {
  id          String    @id @default(cuid())
  guideId     String
  departureId String
  assignedAt  DateTime  @default(now())

  guide       Guide     @relation(fields: [guideId], references: [id])
  departure   Departure @relation(fields: [departureId], references: [id])

  @@unique([guideId, departureId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.NVarChar(Max)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
